# Copy to apps/web/.env and fill in values.

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

BETTER_AUTH_SECRET= # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Optional — leave blank in local dev to log emails instead of sending
RESEND_API_KEY=
EMAIL_SOURCE="just-us <onboarding@resend.dev>"

# Optional — required only for administrator self-registration
# ADMIN_INVITE_CODE=
